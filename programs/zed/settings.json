// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
  "auto_install_extensions": {
    "basher": true,
    "docker-compose": true,
    "dockerfile": true,
    "fish": true,
    "git-firefly": true,
    "golangci-lint": true,
    "harper": true,
    "html": true,
    "make": true,
    "nix": true,
    "pylsp": true,
    "scss": true,
    "terraform": true,
    "toml": true,
    "vue": true,
    "wakatime": true,
  },
}
